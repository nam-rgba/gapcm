<html lang='en'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>Verify your email – Taskee</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
				background-color: #f4f6f9;
				color: #333333;
			}

			.wrapper {
				max-width: 600px;
				margin: 24px auto;
				background-color: #ffffff;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
			}

			.header {
				padding: 24px 32px;
				border-bottom: 1px solid #eeeeee;
			}

			.header-inner {
				display: flex;
				align-items: center;
				gap: 10px;
			}

			.header .brand-name {
				font-size: 20px;
				font-weight: 600;
				color: #6d28d9;
				letter-spacing: 0.5px;
			}

			.body {
				padding: 28px 32px;
			}

			.greeting {
				font-size: 22px;
				font-weight: 700;
				color: #6d28d9;
				margin-bottom: 12px;
			}

			.message {
				font-size: 14px;
				line-height: 1.7;
				color: #555555;
				margin-bottom: 24px;
			}

			.verify-box {
				background-color: #f8f7ff;
				border: 1px solid #e0dcff;
				border-radius: 4px;
				padding: 20px 24px;
				margin-bottom: 24px;
				text-align: center;
			}

			.verify-box .verify-icon {
				font-size: 32px;
				margin-bottom: 12px;
			}

			.verify-box .verify-label {
				font-size: 11px;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.8px;
				color: #7c3aed;
				margin-bottom: 14px;
			}

			.btn-verify {
				display: inline-block;
				background-color: #6d28d9;
				color: #ffffff !important;
				text-decoration: none;
				font-size: 14px;
				font-weight: 600;
				padding: 11px 28px;
				border-radius: 4px;
				letter-spacing: 0.3px;
			}

			.expiry-note {
				font-size: 12px;
				color: #888888;
				margin-top: 12px;
			}

			.fallback-url {
				margin-top: 20px;
			}

			.fallback-url p {
				font-size: 12px;
				color: #888888;
				margin-bottom: 6px;
			}

			.fallback-url a {
				font-size: 12px;
				color: #7c3aed;
				word-break: break-all;
			}

			.divider {
				border: none;
				border-top: 1px solid #eeeeee;
				margin: 24px 0;
			}

			.support-text {
				font-size: 13px;
				color: #888888;
				line-height: 1.7;
			}

			.support-text a {
				color: #6d28d9;
				text-decoration: none;
				font-weight: 500;
			}

			.footer {
				background-color: #f4f6f9;
				padding: 16px 32px;
				text-align: center;
			}

			.footer p {
				font-size: 12px;
				color: #aaaaaa;
				line-height: 1.6;
			}

			.footer a {
				color: #7c3aed;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<div class='wrapper'>
			<!-- Header -->
			<div class='header'>
				<div class='header-inner'>

					<span class='brand-name'>Gapcm</span>
				</div>
			</div>

			<!-- Body -->
			<div class='body'>
				<div class='greeting'>Verify your email, {{name}}!</div>

				<p class='message'>
					Thanks for signing up for
					<strong>Gapcm</strong>. To complete your registration and start using your account, please verify your email
					address by clicking the button below.
				</p>

				<!-- Verify Box -->
				<div class='verify-box'>
					<div class='verify-icon'>✉️</div>
					<div class='verify-label'>Email Verification</div>
					<a href='{{verifyUrl}}' class='btn-verify'>Verify Email Address</a>
					<p class='expiry-note'>This link will expire in <strong>24 hours</strong>.</p>
				</div>

				<!-- Fallback URL -->
				<div class='fallback-url'>
					<p>If the button doesn't work, copy and paste this link into your browser:</p>
					<a href='{{verifyUrl}}'>{{verifyUrl}}</a>
				</div>

				<hr class='divider' />

				<p class='support-text'>
					If you didn't create an account with Gapcm, you can safely ignore this email. For any questions, contact us
					at
					<a href='mailto:support@gapcm.com'>support@gapcm.com</a>.
				</p>
			</div>

			<!-- Footer -->
			<div class='footer'>
				<p>
					© 2026 Gapcm. All rights reserved.<br />
					You're receiving this email because you signed up at
					<a href='https://gapcm.com'>gapcm.com</a>.
				</p>
			</div>
		</div>
	</body>
</html>