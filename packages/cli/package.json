{
  "name": "@gapcm/cli",
  "version": "1.0.5",
  "license": "MIT",
  "description": "CLI scaffolder for building a larger full-stack framework across backend and frontend apps.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "gapcm": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "cli",
    "generator",
    "scaffold",
    "framework",
    "fullstack",
    "backend",
    "frontend",
    "typescript",
    "ejs"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "commander": "^15.0.0",
    "ejs": "^6.0.1",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0"
  }
}
