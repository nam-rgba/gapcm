<html lang='en'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>Welcome to Gapcm</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
				background-color: #f4f6f9;
				color: #333333;
			}

			.wrapper {
				max-width: 600px;
				margin: 24px auto;
				background-color: #ffffff;
				border-radius: 6px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
			}

			.header {
				padding: 24px 32px;
				border-bottom: 1px solid #eeeeee;
			}

			.header-inner {
				display: flex;
				align-items: center;
				gap: 10px;
			}

			.header .brand-name {
				font-size: 20px;
				font-weight: 600;
				color: #6d28d9;
				letter-spacing: 0.5px;
			}

			.body {
				padding: 28px 32px;
			}

			.greeting {
				font-size: 22px;
				font-weight: 700;
				color: #6d28d9;
				margin-bottom: 12px;
			}

			.message {
				font-size: 14px;
				line-height: 1.7;
				color: #555555;
				margin-bottom: 20px;
			}

			.info-card {
				background-color: #f8f7ff;
				border: 1px solid #e0dcff;
				border-radius: 4px;
				padding: 14px 18px;
				margin-bottom: 24px;
			}

			.info-card .info-title {
				font-size: 11px;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.8px;
				color: #7c3aed;
				margin-bottom: 10px;
			}

			.info-card .info-row {
				display: flex;
				align-items: center;
				gap: 10px;
				font-size: 14px;
				color: #444444;
				margin-bottom: 6px;
			}

			.info-card .info-row:last-child {
				margin-bottom: 0;
			}

			.info-card .info-label {
				font-weight: 600;
				min-width: 60px;
				color: #333333;
			}

			.info-card .info-value {
				color: #555555;
			}

			.cta-btn {
				display: inline-block;
				color: #6d28d9;
				text-decoration: underline;
				font-size: 14px;
				font-weight: 600;
			}

			.divider {
				border: none;
				border-top: 1px solid #eeeeee;
				margin: 24px 0;
			}

			.support-text {
				font-size: 13px;
				color: #888888;
				line-height: 1.7;
			}

			.support-text a {
				color: #6d28d9;
				text-decoration: none;
				font-weight: 500;
			}

			.footer {
				background-color: #f4f6f9;
				padding: 16px 32px;
				text-align: center;
			}

			.footer p {
				font-size: 12px;
				color: #aaaaaa;
				line-height: 1.6;
			}

			.footer a {
				color: #7c3aed;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<div class='wrapper'>
			<!-- Header -->
			<div class='header'>
				<div class='header-inner'>
					<span class='brand-name'>Gapcm</span>
				</div>
			</div>

			<!-- Body -->
			<div class='body'>
				<div class='greeting'>Welcome aboard, {{name}}!</div>

				<p class='message'>
					We're thrilled to have you join
					<strong>Gapcm</strong>. Your account has been successfully created and is ready to use.
				</p>

				<!-- Account Info -->
				<div class='info-card'>
					<div class='info-title'>Your Account Details</div>
					<div class='info-row'>
						<span class='info-label'>Name</span>
						<span class='info-value'>{{name}}</span>
					</div>
					<div class='info-row'>
						<span class='info-label'>Email</span>
						<span class='info-value'>{{email}}</span>
					</div>
				</div>

				<a href='https://gapcm.com' class='cta-btn'>Get Started Now</a>

				<hr class='divider' />

				<p class='support-text'>
					If you have any questions or need help getting started, feel free to reach out to our support team at
					<a href='mailto:support@gapcm.com'>support@gapcm.com</a>. We're always here to help.
				</p>
			</div>

			<!-- Footer -->
			<div class='footer'>
				<p>
					© 2026 Gapcm. All rights reserved.<br />
					You're receiving this email because you signed up at
					<a href='https://gapcm.com'>gapcm.com</a>.
				</p>
			</div>
		</div>
	</body>
</html>